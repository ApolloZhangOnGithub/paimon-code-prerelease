{
  "//": "paimon code 统一工具清单。kernel 读取 tools + roles。settings.json tools.disabled 永久禁用。/tools 命令会话级覆盖。locked 工具不可关闭。",
  "tools": {
    "execute":     { "default": true,  "locked": true,  "group": "核心", "desc": "执行 shell 命令 (ls/grep/find 等)" },
    "read":        { "default": true,  "locked": true,  "group": "核心", "desc": "读文件" },
    "write":       { "default": true,  "locked": true,  "group": "核心", "desc": "写新文件" },
    "edit":        { "default": true,  "locked": true,  "group": "核心", "desc": "精确编辑替换" },

    "intentions":  { "default": true,  "locked": true,  "group": "运行", "desc": "意图栈" },
    "wait":        { "default": true,  "locked": false, "group": "运行", "desc": "暂停 N 秒后自动继续" },
    "hibernate":   { "default": true,  "locked": false, "group": "运行", "desc": "休眠等用户" },

    "nap":         { "default": false,  "locked": false, "group": "运行", "desc": "归档旧记忆" },
    "sleep":       { "default": false, "locked": false, "group": "运行", "desc": "独立睡眠进程" },
    
    "mouth":       { "default": true,  "locked": false, "group": "表达", "desc": "TTS 语音" },
    "ear":         { "default": false, "locked": false, "group": "接受", "desc": "语音监听" },

    "terminal":    { "default": true,  "locked": false, "group": "设备", "desc": "建立tmux 终端，可在其中运行命令" },
    "mobile":      { "default": true,  "locked": false, "group": "设备", "desc": "手机控制" },
    "laptop":      { "default": true,  "locked": false, "group": "设备", "desc": "笔记本控制" }
  },
  "roles": {
    "metaconsciousness": ["read_conscious", "aware", "read", "wait"],
    "hippocampus":  ["read", "write", "edit", "wait"],
    "sleep":        ["read", "write", "edit", "wait"]
  }
}
